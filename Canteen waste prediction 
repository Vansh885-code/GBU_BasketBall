      "source": [
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "np.random.seed(42)\n",
        "start_date = datetime(2025, 1, 1)\n",
        "dates = [start_date + timedelta(days=i) for i in range(180)]\n",
        "\n",
        "data = []\n",
        "for date in dates:\n",
        "    day_of_week = date.weekday()\n",
        "    month = date.month\n",
        "    is_holiday = 1 if day_of_week == 6 else 0\n",
        "    if np.random.rand() < 0.05:\n",
        "        is_holiday = 1\n",
        "    weather_choices = ['Sunny', 'Cloudy', 'Rainy']\n",
        "    weather_probs = [0.5, 0.3, 0.2] if month in [3,4,5,6] else [0.3, 0.4, 0.3]\n",
        "    weather = np.random.choice(weather_choices, p=weather_probs)\n",
        "    if month in [12,1,2]: temp = np.random.randint(10, 20)\n",
        "    elif month in [3,4,5]: temp = np.random.randint(25, 40)\n",
        "    elif month in [6,7,8,9]: temp = np.random.randint(22, 32)\n",
        "    else: temp = np.random.randint(15, 25)\n",
        "    event = np.random.choice(['None', 'Exam', 'Fest'], p=[0.85, 0.1, 0.05])\n",
        "    base_students = 450\n",
        "    if is_holiday: base_students = 50\n",
        "    if day_of_week == 4: base_students = 380\n",
        "    if event == 'Exam': base_students = 500\n",
        "    if event == 'Fest': base_students = 200\n",
        "    total_students = int(base_students + np.random.randint(-50, 50))\n",
        "    total_students = max(20, total_students)\n",
        "    meals_prepared_kg = total_students * 0.4 + np.random.randint(10, 30)\n",
        "    consumption_rate = 0.85\n",
        "    if weather == 'Rainy': consumption_rate = 0.92\n",
        "    if event == 'Exam': consumption_rate = 0.75\n",
        "    if day_of_week == 4: consumption_rate = 0.78\n",
        "    if is_holiday: consumption_rate = 0.70\n",
        "    meals_consumed_kg = meals_prepared_kg * consumption_rate + np.random.normal(0, 5)\n",
        "    meals_consumed_kg = min(meals_prepared_kg, meals_consumed_kg)\n",
        "    waste_kg = meals_prepared_kg - meals_consumed_kg\n",
        "    waste_kg = max(2, waste_kg)\n",
        "    data.append([\n",
        "        date.strftime('%Y-%m-%d'),\n",
        "        day_of_week,\n",
        "        is_holiday,\n",
        "        weather,\n",
        "        temp,\n",
        "        event,\n",
        "        total_students,\n",
        "        round(meals_prepared_kg, 2),\n",
        "        round(meals_consumed_kg, 2),\n",
        "        round(waste_kg, 2)\n",
        "    ])\n",
        "\n",
        "df = pd.DataFrame(data, columns=[\n",
        "    'date', 'day_of_week', 'is_holiday', 'weather', 'temperature',\n",
        "    'special_event', 'total_students', 'meals_prepared_kg',\n",
        "    'meals_consumed_kg', 'waste_kg'\n",
        "])\n",
        "df.to_csv('canteen_waste.csv', index=False)\n",
        "print(df.head())\n",
        "print(df.shape)"
      ],
